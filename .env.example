EXCHANGE_API_KEY=your_api_key_here
EXCHANGE_API_SECRET=your_api_secret_here
EXCHANGE_SANDBOX=true
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Neon Postgres for Vercel dashboard (get from https://console.neon.tech)
NEON_DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/richbot?sslmode=require
CLOUD_ENABLED=true
CLOUD_BOT_ID=richbot-pi
