# Neon Postgres — get these from https://console.neon.tech
DATABASE_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/richbot?sslmode=require"
DIRECT_DATABASE_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/richbot?sslmode=require"

# Must match the bot_id in config.json / config_pi.json
BOT_ID="richbot-pi"

# Dashboard password (optional; if not set, no login required)
DASHBOARD_PASSWORD=""

# Web Push / Alerts (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
ALERT_WEBHOOK_SECRET=""
