  "database": {
    "path": "data/richbot.db"
  },
  "cloud": {
    "enabled": true,
    "database_url": "",
    "bot_id": "richbot-pi",
    "heartbeat_interval": 30,
    "command_poll_interval": 5,
    "sync_trades": true,
    "sync_equity": true
  },
  "pi": {
    "enabled": true,
    "memory_limit_mb": 512,
    "gc_interval_seconds": 300,
    "equity_history_limit": 2000,
    "ohlcv_fetch_limit": 300,
    "use_tflite": true,
    "numpy_float32": true
