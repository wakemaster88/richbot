{
  "exchange": {
    "name": "binance",
    "api_key": "",
    "api_secret": "",
    "sandbox": true,
    "rate_limit": true
  },
  "pairs": ["BTC/USDT"],
  "grid": {
    "grid_count": 12,
    "spacing_percent": 0.5,
